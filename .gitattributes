# Auto-detect text files and normalise line endings
*       text=auto

# C++ source
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf

# Build system
*.txt   text eol=lf
*.cmake text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# Binary files (no line-ending conversion)
*.png   binary
*.pdf   binary
*.ttf   binary
